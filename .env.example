# Dotfiles Environment Configuration
# Copy this file to .env and fill in your credentials
# DO NOT COMMIT .env to git (it's in .gitignore)

# ────────────────────────────────────────────────────────
# PERSONAL DIRECTORIES (These should be per-machine)
# ────────────────────────────────────────────────────────

# Project directories
PROJECTS_DIR="$HOME/Desktop/personal"
ORBIT_DIR="$HOME/Desktop/orbit"

# Personal directories (comment out what you don't use)
MOENMARIN_DIR="$HOME/Desktop/moen-marin"
DATAING_DIR="$HOME/Desktop/ntnu"

# ────────────────────────────────────────────────────────
# HARDWARE-SPECIFIC SETTINGS (These should be per-machine)
# ────────────────────────────────────────────────────────

# Monitor configuration
# LAPTOP (single display)
# MONITOR_PRIMARY="eDP-1"
# MONITOR_SECONDARY=""

# DESKTOP (triple display)
# MONITOR_PRIMARY="HDMI-A-1"  
# MONITOR_SECONDARY="DP-1"
# MONITOR_TERTIARY="DP-3"

# WORKSTATION (dual display)
# MONITOR_PRIMARY="DP-1"
# MONITOR_SECONDARY="DP-2"

# ────────────────────────────────────────────────────────
# PERSONAL PREFERENCES (These should be per-machine)
# ────────────────────────────────────────────────────────

# Default editors/tools you prefer
DEFAULT_EDITOR="nvim"
DEFAULT_BROWSER="brave"
DEFAULT_TERMINAL="ghostty"

# Development preferences
NODE_VERSION="20"
PYTHON_VERSION="3.11"
RUST_TOOLCHAIN="stable"

# ────────────────────────────────────────────────────────
# NETWORK CONFIGURATIONS (These should be per-machine)
# ────────────────────────────────────────────────────────

# SSH identities (if different from ~/.ssh/id_rsa)
# SSH_IDENTITY="/path/to/your/key.pem"

# Network interfaces (for monitoring)
# WIFI_INTERFACE="wlan0"
# ETHERNET_INTERFACE="eth0"

# ────────────────────────────────────────────────────────
# THEME PREFERENCES (Can be shared or per-machine)
# ────────────────────────────────────────────────────────

# Theme variants
# GTK_THEME="Adwaita-dark"
# QT_THEME="Breeze"
# TERMINAL_THEME="tokyonight"

# Color schemes (NeoVim)
# NVIM_COLORSCHEME="tokyonight-night"

# ────────────────────────────────────────────────────────
# PERFORMANCE TUNING (These should be per-machine)
# ────────────────────────────────────────────────────────

# CPU governor (performance/powersave)
# CPU_GOVERNOR="ondemand"

# Power management
# DISABLE_BLUETOOTH_ON_BATTERY="yes"
# DIM_SCREEN_ON_BATTERY="yes"

# ────────────────────────────────────────────────────────
# DEVELOPMENT ENVIRONMENT (Can be shared or per-machine)
# ────────────────────────────────────────────────────────

# Work email/tools
# WORK_EMAIL="your.work@email.com"
# WORK_CALENDAR="work-calendar"

# API endpoints (comment out - don't commit real keys!)
# NOTION_API_KEY="your-notion-key"
# GITHUB_TOKEN="your-github-token"

# ────────────────────────────────────────────────────────
# AUTO-DETECTED (Don't modify - these are detected automatically)
# ────────────────────────────────────────────────────────

# Machine type (DETECT THIS)
# MACHINE_TYPE="laptop|desktop|workstation"

# Monitor setup (DETECT THIS)
# MONITOR_COUNT="1|2|3"

# GPU type (DETECT THIS)
# GPU="nvidia|amd|intel|hybrid"