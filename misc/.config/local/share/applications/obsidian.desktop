[Desktop Entry]
Name=Obsidian
Exec=/usr/bin/obsidian %U
Terminal=false
Type=Application
Icon=obsidian
StartupWMClass=obsidian
Comment=Obsidian
MimeType=x-scheme-handler/obsidian;
Categories=Office;

# force wayland to avoid blurring on arch
Exec=env OBSIDIAN_USE_WAYLAND=1 obsidian --enable-features=UseOzonePlatform,WaylandWindowDecorations --ozone-platform=wayland %U

