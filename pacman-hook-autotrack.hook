# Pacman hook - Auto-track packages after install
# This runs after every pacman transaction

[Trigger]
Operation = Install
Operation = Upgrade
Operation = Remove
Type = Package
Target = *

[Action]
Description = Auto-track packages in dotfiles...
When = PostTransaction
Exec = /bin/sh -c 'for dir in $HOME/Desktop/dotfiles $HOME/dotfiles $HOME/.dotfiles; do if [ -f "$dir/scripts/pkgtrack_auto.sh" ]; then bash "$dir/scripts/pkgtrack_auto.sh"; break; fi; done || true'